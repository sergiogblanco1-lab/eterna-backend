import os
from pydantic import BaseModel


class Settings(BaseModel):

    # rutas
    uploads_dir: str = "storage/uploads"
    exports_dir: str = "storage/exports"
    reactions_dir: str = "storage/reactions"

    # ffmpeg
    ffmpeg_path: str = "ffmpeg"

    # base de datos
    database_url: str = os.getenv("DATABASE_URL", "sqlite:///eterna.db")

    # dominio público (para enlaces que enviamos)
    public_base_url: str = os.getenv(
        "PUBLIC_BASE_URL",
        "https://eterna-backend-0six.onrender.com"
    )


settings = Settings()
